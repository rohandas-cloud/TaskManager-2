<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Required for WorkManager notifications on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".application.TaskManagerApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_foreground"
        android:supportsRtl="true"
        android:theme="@style/Theme.TaskManagerPro">

        <!--
            FIX: All activity names corrected to match their actual package paths.
            Previously many were declared as ".ActivityName" (root package) but the
            source files lived in sub-packages, causing ClassNotFoundException on launch.
        -->

        <!-- Launcher: SplashActivity (auth gate) -->
        <!-- FIX: was ".SplashActivity" → corrected to full sub-package path -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.TaskManagerPro">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Auth screens -->
        <!-- FIX: was ".LoginActivity" → corrected -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".ui.auth.OnboardingActivity"
            android:exported="false" />

        <!-- Main / Dashboard -->
        <activity
            android:name=".ui.dashboard.MainActivity"
            android:exported="false" />

        <!-- Task screens -->
        <!-- FIX: was ".AddProjectActivity" → corrected -->
        <activity
            android:name=".ui.task.AddProjectActivity"
            android:exported="false" />
        <activity
            android:name=".ui.task.TodayTasksActivity"
            android:exported="false" />

        <!-- Other screens -->
        <activity
            android:name=".ui.calendar.CalendarActivity"
            android:exported="false" />
        <activity
            android:name=".ui.profile.ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".ui.notification.NotificationsActivity"
            android:exported="false" />

    </application>
</manifest>
