<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#20FFFFFF">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/premium_violet"
                android:startColor="@color/premium_indigo"
                android:type="linear" />
            <corners android:radius="32dp" />
            <padding
                android:bottom="12dp"
                android:left="24dp"
                android:right="24dp"
                android:top="12dp" />
        </shape>
    </item>
</ripple>
